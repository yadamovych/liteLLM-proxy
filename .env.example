# Copy to .env:  cp .env.example .env

LITELLM_MASTER_KEY=CHANGE_ME_TO_A_RANDOM_SECURE_KEY

# Admin UI: http://localhost:4000/ui
UI_USERNAME=admin
UI_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# AWS (mounted from host ~/.aws into the container)
AWS_PROFILE=your-aws-profile-name
AWS_REGION=your-aws-region

# Optional
LITELLM_COST_FOOTER=1
# LITELLM_LOG=INFO
# LITELLM_DEBUG=1

# AWS profile and region (optional - will use default from ~/.aws if not set)
# AWS_PROFILE=
# AWS_REGION=

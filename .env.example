# Copy to .env:  cp .env.example .env

LITELLM_MASTER_KEY=sk-local-litellm-bedrock

# Admin UI: http://localhost:4000/ui
UI_USERNAME=admin
UI_PASSWORD=changeme

# AWS (mounted from host ~/.aws into the container)
AWS_PROFILE=YOUR_AWS_PROFILE_NAME
AWS_REGION=eu-central-1
# AWS_CONFIG_DIR=/home/yurii/.aws   # override if compose cannot resolve $HOME

# Optional
LITELLM_COST_FOOTER=1
# LITELLM_LOG=INFO
# LITELLM_DEBUG=1

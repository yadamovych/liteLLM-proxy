{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start LiteLLM Bedrock Proxy",
      "type": "shell",
      "command": "./scripts/start.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start LiteLLM Bedrock Proxy (debug)",
      "type": "shell",
      "command": "./scripts/start.sh --debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Verify LiteLLM Proxy",
      "type": "shell",
      "command": "./scripts/verify-proxy.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
